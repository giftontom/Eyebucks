# Database
DATABASE_URL="postgresql://user:password@localhost:5432/eyebuckz?schema=public"

# Server
PORT=4000
NODE_ENV=development

# CORS
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# JWT/Session
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters"
SESSION_SECRET="your-super-secret-session-key-minimum-32-characters"

# Razorpay (Optional - will use mock mode if not set)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret_here"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret_here"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Cloudinary (Video Hosting)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@eyebuckz.com"

# Application URL (for email links and certificate URLs)
APP_URL="http://localhost:5173"

# Admin
ADMIN_EMAILS="admin@eyebuckz.com,owner@eyebuckz.com"
