# ============================================
# EYEBUCKZ LMS - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!

# ============================================
# SUPABASE (REQUIRED)
# ============================================
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...your_supabase_anon_key_here

# ============================================
# APPLICATION SETTINGS
# ============================================
VITE_APP_NAME=Eyebuckz
VITE_APP_URL=http://localhost:3000

# ============================================
# RAZORPAY PAYMENT GATEWAY (PUBLIC KEY)
# ============================================
# Get from: https://dashboard.razorpay.com/app/keys
# Only the public key ID is needed on the frontend
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# ============================================
# SENTRY (ERROR TRACKING - OPTIONAL)
# ============================================
# VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ============================================
# ANALYTICS (OPTIONAL)
# ============================================
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# DEVELOPMENT MODE
# ============================================
# Mock payment mode (skip actual Razorpay in development)
VITE_MOCK_PAYMENT=true

# Enable detailed logging
VITE_DEBUG_MODE=true

# ============================================
# SUPABASE EDGE FUNCTION SECRETS
# ============================================
# These are set via `supabase secrets set` CLI, NOT in .env
# Listed here for documentation only:
#
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...
# BUNNY_STREAM_API_KEY=...
# BUNNY_STREAM_LIBRARY_ID=...
# BUNNY_STREAM_CDN_HOSTNAME=vz-xxxxx.b-cdn.net
# BUNNY_STREAM_TOKEN_KEY=...
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@eyebuckz.com
# ADMIN_EMAILS=admin@eyebuckz.com
# APP_URL=https://eyebuckz.com

# ============================================
# NOTES
# ============================================
# 1. Never commit .env.local to Git
# 2. Add .env.local to .gitignore
# 3. Server-side secrets (Razorpay, Bunny, Resend) go in Supabase Edge Function secrets
# 4. Only VITE_* variables are exposed to the frontend
# 5. Google OAuth is configured in Supabase Dashboard > Auth > Providers
